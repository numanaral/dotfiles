# Server Setup Configuration
# Copy to .env and fill in values before running setup.sh.
# Priority: flags > .env > interactive prompts.

# Required
SETUP_USER=numanaral
SETUP_GIT_NAME=numanaral
SETUP_GIT_EMAIL=

# Optional (prompted if empty)
SETUP_DOMAIN=numanaral.dev
SETUP_SWAP_SIZE=4G
SETUP_PYTHON_VERSION=3.12
SETUP_NODE_VERSION=22
